# Application
APP_NAME=UEBA Detection API
APP_VERSION=1.0.0
DEBUG=false

# Database — TimescaleDB (detection-db container)
DB_HOST=detection-db
DB_PORT=5433
DB_USER=fraud
DB_PASSWORD=fraud_password
DB_NAME=fraud_detection

# API Keys (comma-separated for multiple keys per scope)
SYSLOG_API_KEYS=syslog-key-here
RAW_API_KEYS=raw-key-here
WAZUH_API_KEYS=wazuh-key-here
DELINEA_API_KEYS=delinea-key-here
ADMIN_API_KEYS=admin-key-here

# CORS
CORS_ORIGINS=*

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Logging
LOG_LEVEL=INFO

# Dev
RELOAD=true
