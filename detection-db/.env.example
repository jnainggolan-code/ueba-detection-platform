# =============================================================================
# detection-db — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values before starting the container.

# Database
POSTGRES_DB=fraud_detection
POSTGRES_USER=fraud
POSTGRES_PASSWORD=changeme

# Connection (internal Docker network)
POSTGRES_HOST=detection-db
POSTGRES_PORT=5433

# TimescaleDB tuning (optional)
# TS_TUNE_MEMORY_MB=2048
# TS_TUNE_NUM_CPUS=4
