# =============================================================================
# UEBA Detection Platform — .env.example
# =============================================================================
# Copy this to .env and fill in the values before running docker compose

# ── Database ──
POSTGRES_DB=ueba_detection
POSTGRES_USER=ueba_admin
POSTGRES_PASSWORD=changeme_strong_password_here

# ── API ──
LOG_LEVEL=info

# ── Dashboard ──
# URL for the detection-api from the browser/client perspective
VITE_API_URL=http://100.107.189.94:8081
